{
  "schema": "joblane.workflow.v1",
  "id": "experiment",
  "version": "0.1.0",
  "orchestrator": "joblane",
  "stages": [
    {"id": "prepare_packet", "kind": "fixture_or_provider"},
    {"id": "approve_or_skip", "kind": "human_gate"},
    {"id": "stage_experiment_output", "kind": "sandbox_effect"}
  ],
  "gates": [
    {
      "id": "approve_or_skip",
      "allowed_decisions": ["approve", "skip"],
      "content_bound": true
    }
  ],
  "live_effects": false,
  "execution": {
    "artifact": {
      "id": "{run_id}:experiment_packet",
      "kind": "experiment_packet",
      "content_from": "artifact"
    },
    "gate": {
      "id": "approve_or_skip",
      "prompt": "Approve today's experiment output or skip it.",
      "allowed_decisions": ["approve", "skip"],
      "action": "stage_experiment_output"
    },
    "status": "waiting"
  }
}
