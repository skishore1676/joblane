{
  "schema": "joblane.workflow.v1",
  "id": "public_presence",
  "version": "0.1.0",
  "orchestrator": "joblane",
  "stages": [
    {"id": "collect_context", "kind": "fixture_or_provider"},
    {"id": "draft_packet", "kind": "provider"},
    {"id": "taste_gate", "kind": "human_gate"},
    {"id": "stage_public_draft", "kind": "sandbox_effect"}
  ],
  "gates": [
    {
      "id": "taste_gate",
      "allowed_decisions": ["approve", "revise", "park", "reject"],
      "content_bound": true
    }
  ],
  "live_effects": false,
  "execution": {
    "artifact": {
      "id": "{run_id}:publish_packet",
      "kind": "publish_packet",
      "content_from": "artifact"
    },
    "gate": {
      "id": "taste_gate",
      "prompt": "Approve, revise, park, or reject this draft packet.",
      "allowed_decisions": ["approve", "revise", "park", "reject"],
      "action": "stage_public_draft"
    },
    "status": "waiting"
  }
}
