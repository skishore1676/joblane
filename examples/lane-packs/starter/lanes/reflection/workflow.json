{
  "schema": "joblane.workflow.v1",
  "id": "reflection",
  "version": "0.1.0",
  "orchestrator": "joblane",
  "stages": [
    {"id": "write_fast_observation", "kind": "memory_fast"},
    {"id": "recall_weekly", "kind": "memory_recall"},
    {"id": "propose_takeaway", "kind": "companion"},
    {"id": "memory_gate", "kind": "human_gate"},
    {"id": "promote_reflection_memory", "kind": "memory_effect"}
  ],
  "gates": [
    {
      "id": "memory_gate",
      "allowed_decisions": ["approve", "reject", "revise"],
      "content_bound": true
    }
  ],
  "live_effects": false,
  "execution": {
    "memory_fast": [
      {
        "namespace": "weekly",
        "key": "current_session",
        "value_from": "fast_memory",
        "sensitivity": "private"
      }
    ],
    "memory_candidate": {
      "namespace": "weekly",
      "kind": "operating_principle",
      "memory_from": "memory_candidate",
      "sensitivity": "internal"
    },
    "artifact": {
      "id": "{run_id}:memory_takeaway",
      "kind": "memory_takeaway",
      "content_from": "artifact",
      "candidate_field": "candidate_id"
    },
    "gate": {
      "id": "memory_gate",
      "prompt": "Promote this reflection takeaway to durable memory?",
      "allowed_decisions": ["approve", "reject", "revise"],
      "action": "promote_reflection_memory"
    },
    "companion": {
      "namespace": "weekly",
      "candidate_kind": "operating_principle",
      "candidate_sensitivity": "internal"
    },
    "status": "waiting"
  }
}
